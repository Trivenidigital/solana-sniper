# === Solana RPC ===
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# === Wallet ===
KEYPAIR_PATH=wallet.json          # Auto-generated on first run

# === Scout DB (read-only) ===
SCOUT_DB_PATH=../coinpump-scout/scout.db

# === Sniper DB ===
SNIPER_DB_PATH=sniper.db

# === Risk Controls ===
MAX_BUY_SOL=0.1                   # Max SOL per trade
MAX_PORTFOLIO_SOL=1.0             # Max total exposure
MAX_OPEN_POSITIONS=5              # Max concurrent positions
STOP_LOSS_PCT=35.0                # Close if down 35%
TAKE_PROFIT_PCT=100.0             # Close if up 100% (2x)
MIN_CONVICTION_SCORE=70.0         # Min score to consider buying
MIN_LIQUIDITY_USD=15000.0         # Don't buy illiquid tokens
MAX_TOKEN_AGE_DAYS=3              # Skip tokens older than 3 days

# === Cooldown ===
COOLDOWN_HOURS=6                  # Hours to wait before re-buying after stop-loss

# === Trailing Take-Profit ===
TRAILING_TRIGGER_PCT=50.0         # Activate trailing after 50% gain
TRAILING_STOP_PCT=20.0            # Sell if drops 20% from peak

# === Partial Exits ===
PARTIAL_SELL_FRACTION=0.5         # Sell 50% at half take-profit

# === Jupiter ===
JUPITER_API_URL=https://lite-api.jup.ag/swap/v1
JUPITER_FALLBACK_URL=https://api.jup.ag/swap/v1
SLIPPAGE_BPS=300                  # 3% slippage tolerance
JUPITER_TIMEOUT_SEC=30

# === Execution ===
PAPER_MODE=true                   # Paper trading by default (set false for live)
POLL_INTERVAL_SECONDS=30          # Signal check interval
POSITION_CHECK_INTERVAL_SECONDS=10
PRIORITY_FEE_LAMPORTS=100000      # Fallback priority fee
PRIORITY_FEE_AUTO=true            # Use Jupiter auto priority fees

# === Split Orders ===
SPLIT_ORDERS=false                # Split buys into multiple orders
SPLIT_COUNT=3                     # Number of splits
SPLIT_DELAY_SECONDS=10            # Delay between splits

# === Telegram Notifications ===
TELEGRAM_BOT_TOKEN=                # Your Telegram bot token
TELEGRAM_CHAT_ID=                  # Your Telegram chat ID
