# === Solana RPC ===
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# === Wallet ===
KEYPAIR_PATH=wallet.json          # Auto-generated on first run

# === Scout DB (read-only) ===
SCOUT_DB_PATH=../coinpump-scout/scout.db

# === Sniper DB ===
SNIPER_DB_PATH=sniper.db

# === Risk Controls ===
MAX_BUY_SOL=0.1                   # Max SOL per trade
MAX_PORTFOLIO_SOL=1.0             # Max total exposure
MAX_OPEN_POSITIONS=5              # Max concurrent positions
STOP_LOSS_PCT=25.0                # Close if down 25%
TAKE_PROFIT_PCT=100.0             # Close if up 100% (2x)
MIN_CONVICTION_SCORE=70.0         # Min score to consider buying
MIN_LIQUIDITY_USD=15000.0         # Don't buy illiquid tokens

# === Jupiter ===
JUPITER_API_URL=https://lite-api.jup.ag/swap/v1
SLIPPAGE_BPS=300                  # 3% slippage tolerance
JUPITER_TIMEOUT_SEC=30

# === Execution ===
PAPER_MODE=true                   # Paper trading by default (set false for live)
POLL_INTERVAL_SECONDS=30          # Signal check interval
POSITION_CHECK_INTERVAL_SECONDS=15
PRIORITY_FEE_LAMPORTS=100000      # Priority fee for faster inclusion
